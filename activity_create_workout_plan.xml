<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".Create_Workout_Plan">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:title="Make your own workout plan"
        android:paddingTop="20dp"
        app:titleCentered="true"
        app:titleTextColor="#00BFA5"
        app:navigationIcon="@drawable/outline_arrow_back_24"
        app:navigationIconTint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <EditText
                android:id="@+id/etWorkoutName"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@android:color/transparent"
                android:backgroundTint="#00BFA5"
                android:hint="Workout name"
                android:inputType="textPersonName"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="16sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <View
                android:id="@+id/dividerInput"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#00FF88"
                app:layout_constraintTop_toBottomOf="@id/etWorkoutName"/>

            <TextView
                android:id="@+id/tvSelectDayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Day of the week"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/dividerInput"
                app:layout_constraintStart_toStartOf="parent"/>

            <HorizontalScrollView
                android:id="@+id/svDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tvSelectDayLabel">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMonday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mon"
                        android:textColor="#121212"
                        android:background="#00BFA5"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:layout_marginEnd="8dp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvTuesday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tue"
                        android:textColor="#8E8E93"
                        android:background="#222222"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvWednesday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wed"
                        android:textColor="#8E8E93"
                        android:background="#222222"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvThursday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thu"
                        android:textColor="#8E8E93"
                        android:background="#222222"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvFriday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fri"
                        android:textColor="#8E8E93"
                        android:background="#222222"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:layout_marginEnd="8dp"/>

                </LinearLayout>

            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvExercisesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Exercises"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/svDays"
                app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout
                android:id="@+id/llExercisesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvExercisesTitle"/>

            <TextView
                android:id="@+id/btnAddNewExercise"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="#2C2C2E"
                android:gravity="center"
                android:text="+ ADD AN EXERCISE"
                android:textColor="#00BFA5"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/llExercisesContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <Button
                android:id="@+id/btnSavePlan"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="SAVE WORKOUT PLAN"
                android:textColor="#121212"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#00BFA5"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/btnAddNewExercise"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="#00BFA5"
        app:itemTextColor="#00BFA5"
        app:itemActiveIndicatorStyle="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>