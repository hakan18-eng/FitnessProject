                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/dumbell_squats" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
