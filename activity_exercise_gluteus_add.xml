<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Exercise_Gluteus_Add"
    android:background="#000000">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:paddingTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="@drawable/outline_arrow_back_24"
        app:navigationIconTint="#00BFA5"
        app:title="GLUTEUS"
        app:titleCentered="true"
        app:titleTextColor="#00BFA5"
        app:titleTextAppearance="@style/ToolbarTitleText"/>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/LegBarbellLunges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="centerCrop"
                        android:src="@drawable/leg_barbell_lunges" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Leg barbell lunges"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddBarbellLunges"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/BandedCrabWalk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banded_crab_walk" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Banded crab walk"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddCrabWalk"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/BandedLateralRaise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banded_lateral_raise" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Banded lateral raise"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnAddLateralRaise"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/GluteBridge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="centerCrop"
                        android:src="@drawable/glute_bridge" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Glute bridge"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddGluteBridge"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/BulgarianSplitSquat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/bulgarian_split_squat" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bulgarian split squat"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddBulgarianSquat"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/Deadlift"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/deadlift" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Deadlift"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddDeadlift"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/DonkeyKick"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/donkey_kick" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Donkey kick"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddDonkeyKick"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/GlutesExtension"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/glutes_extension" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Glutes extension"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddGlutesExtension"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/PileDumbellSquats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/pile_dumbell_squats" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Plie dumbbell squats"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddPlieSquats"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        app:itemActiveIndicatorStyle="@null"
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="#00BFA5"
        app:itemTextColor="#00BFA5"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>