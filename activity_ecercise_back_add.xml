<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Ecercise_Back_Add"
    android:background="#000000">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:paddingTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="@drawable/outline_arrow_back_24"
        app:navigationIconTint="#00BFA5"
        app:title="BACK"
        app:titleCentered="true"
        app:titleTextColor="#00BFA5"
        app:titleTextAppearance="@style/ToolbarTitleText"/>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/PullUpBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:scaleType="fitCenter"
                        android:background="#000000"
                        android:src="@drawable/back_pull_up" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pull up"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnAddPullUp"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/CloseGripLatPulldown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:scaleType="fitCenter"
                        android:background="#000000"
                        android:src="@drawable/clode_grip_lat_pulldown" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Close grip lat pulldown"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddCloseGripLat"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/WideCableRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/wide_cable_row" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wide cable row"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddWideCableRow"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/TBarRowWide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/t_bar_row_wade" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="T bar row wide"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddTBarRowWide"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/LatPulldown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/lat_pulldown" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lat pulldown"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddLatPulldown"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/TRXrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/trx_row" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TRX row"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddTRXrow"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/RopePullover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/rope_pullover" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rope pullover"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddRopePullover"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/RopeFacePullover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/rope_face_pullover" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rope face pullover"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddRopeFacePullover"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/NarrowGripRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="#000000"
                        android:scaleType="fitCenter"
                        android:src="@drawable/narrow_grip_row" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Narrow grip row"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnAddNarrowGripRow"
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:text="ADD"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1C1C1E"
                        android:textColor="#00BFA5"
                        app:strokeColor="#00BFA5"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp"
                        android:padding="0dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        app:itemActiveIndicatorStyle="@null"
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="#00BFA5"
        app:itemTextColor="#00BFA5"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>